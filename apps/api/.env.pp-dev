# Plane Plus — API env for docker-compose.pp-dev.yml (Orbstack)
# Copy to apps/api/.env before running: cp apps/api/.env.pp-dev apps/api/.env

# Django
SECRET_KEY=pp-dev-secret-key-not-for-production
DEBUG=1
CORS_ALLOWED_ORIGINS=https://plane.orb.local,http://plane.orb.local,http://localhost:3000,http://localhost:3001,http://localhost:3002

# Database — container DNS on compose network
POSTGRES_USER=plane
POSTGRES_PASSWORD=plane
POSTGRES_HOST=pp-db
POSTGRES_DB=plane
POSTGRES_PORT=5432
DATABASE_URL=postgresql://plane:plane@pp-db:5432/plane

# Redis
REDIS_HOST=pp-redis
REDIS_PORT=6379
REDIS_URL=redis://pp-redis:6379/

# RabbitMQ
RABBITMQ_HOST=pp-mq
RABBITMQ_PORT=5672
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=plane
RABBITMQ_VHOST=plane

# Minio / S3 — internal URL for API server (container-to-container)
AWS_REGION=
AWS_ACCESS_KEY_ID=access-key
AWS_SECRET_ACCESS_KEY=secret-key
AWS_S3_ENDPOINT_URL=http://pp-minio:9000
AWS_S3_BUCKET_NAME=uploads
FILE_SIZE_LIMIT=5242880
SIGNED_URL_EXPIRATION=3600

# Docker
DOCKERIZED=1
USE_MINIO=1

# URLs — Orbstack DNS
WEB_URL=https://plane.orb.local

# Gunicorn
GUNICORN_WORKERS=2

# Base URLs — all go through the proxy
ADMIN_BASE_URL=https://plane.orb.local
ADMIN_BASE_PATH=/god-mode

SPACE_BASE_URL=https://plane.orb.local
SPACE_BASE_PATH=/spaces

APP_BASE_URL=https://plane.orb.local
APP_BASE_PATH=

LIVE_BASE_URL=https://plane.orb.local
LIVE_BASE_PATH=/live

LIVE_SERVER_SECRET_KEY=secret-key

# Cleanup
HARD_DELETE_AFTER_DAYS=60

# Minio SSL
MINIO_ENDPOINT_SSL=0

# API key rate limit
API_KEY_RATE_LIMIT=60/minute
