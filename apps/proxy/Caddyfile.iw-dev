# InfraWatch dev proxy — maps to iw-* container names
(plane_proxy) {
	request_body {
		max_size {$FILE_SIZE_LIMIT}
	}

	redir /spaces /spaces/ permanent
	reverse_proxy /spaces/* iw-space:3002

	redir /god-mode /god-mode/ permanent
	reverse_proxy /god-mode/* iw-admin:3001

	reverse_proxy /live/* iw-live:3003

	reverse_proxy /api/* iw-api:8000

	reverse_proxy /auth/* iw-api:8000

	reverse_proxy /static/* iw-api:8000

	reverse_proxy /{$BUCKET_NAME}/* iw-minio:9000
	reverse_proxy /{$BUCKET_NAME} iw-minio:9000

	reverse_proxy /litellm/* iw-litellm:4000

	reverse_proxy /* iw-web:3000
}

{
	auto_https off
	servers {
		max_header_size 25MB
		client_ip_headers X-Forwarded-For X-Real-IP
		trusted_proxies static {$TRUSTED_PROXIES:0.0.0.0/0}
	}
}

{$SITE_ADDRESS} {
	import plane_proxy
}
