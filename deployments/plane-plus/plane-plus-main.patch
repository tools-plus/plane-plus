+          if [ "$IS_RELEASE" == "true" ] && [ "$IS_PRERELEASE" != "true" ]; then
+            # Full release: version + stable
+            TAGS="${TAGS},${ORG}/${IMAGE}:stable"
+          elif [ "$IS_RELEASE" != "true" ] && [ "$TAG" == "main" ]; then
+            # Branch build from main: branch-name + latest
